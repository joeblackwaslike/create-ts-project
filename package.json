{
  "name": "spinup-ts",
  "version": "0.1.0",
  "description": "Scaffold a production-ready TypeScript project with opinionated tooling (Biome, ESLint strict, Vitest, Husky, GitHub Actions, Docusaurus, Docker, devcontainer). The TypeScript sibling of spinup-py.",
  "type": "module",
  "bin": {
    "spinup-ts": "./dist/index.js"
  },
  "files": ["dist", "template"],
  "homepage": "https://github.com/joeblackwaslike/spinup-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeblackwaslike/spinup-ts.git"
  },
  "bugs": {
    "url": "https://github.com/joeblackwaslike/spinup-ts/issues"
  },
  "keywords": [
    "typescript",
    "scaffold",
    "cli",
    "template",
    "boilerplate",
    "starter",
    "biome",
    "eslint",
    "vitest",
    "docusaurus"
  ],
  "author": "Joe Black <joeblackwaslike@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "biome ci . && eslint . --max-warnings=0",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "commit": "cz",
    "prepare": "husky",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "degit": "^2.8.4",
    "fs-extra": "^11.2.0",
    "globby": "^14.0.2",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/degit": "^2.8.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.28.0",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "src/**/*.ts": ["eslint --fix --max-warnings=0 --no-warn-ignored"]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
