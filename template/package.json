{
  "name": "__PROJECT_NAME__",
  "version": "0.1.0",
  "description": "__DESCRIPTION__",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "biome ci . && eslint . --max-warnings=0",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "depcheck": "depcheck",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.28.0",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitepress": "^1.6.3",
    "vitest": "^3.0.0"
  },
  "__lint-staged__": {
    "*.{ts,js,json,md}": ["biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"],
    "*.ts": ["eslint --fix --max-warnings=0 --no-warn-ignored"]
  },
  "author": "__AUTHOR__ <__EMAIL__>",
  "license": "__LICENSE__",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/__GITHUB_HANDLE__/__PROJECT_NAME__.git"
  },
  "engines": {
    "node": ">=__NODE_VERSION__"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "unrs-resolver"]
  }
}
